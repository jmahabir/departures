[Unit]
Description=Solari Board Flask App
After=network.target

[Service]
User=www-data
WorkingDirectory=/var/www/solari-board
ExecStart=/usr/bin/python3 -m gunicorn \
    --workers 2 \
    --bind 127.0.0.1:5000 \
    --timeout 60 \
    app:app
Restart=always
RestartSec=5
Environment=PYTHONUNBUFFERED=1

[Install]
WantedBy=multi-user.target
